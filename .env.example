# --- Node API (src/) ---
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/ai_smart_hospital
JWT_SECRET=replace_me_with_a_32_char_random_string
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3001

# --- Service URLs (used by Node API to reach Python services) ---
ML_SERVICE_BASE_URL=http://127.0.0.1:5000
AGENT_SERVICE_BASE_URL=http://127.0.0.1:7000
BERT_INFERENCE_URL=http://127.0.0.1:5000/infer

# --- Python agent service (LangGraph + Gemini) ---
# Optional: leave blank to use the deterministic fallback summary
GEMINI_API_KEY=

# --- Frontend (frontend2/) ---
# In docker compose this should be http://api:3000 inside the network
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
